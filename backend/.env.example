# ── LinkVeil-AI Environment Configuration ──

# Google Gemini API Key (Required for LLM Reasoning & Forensic Interpretation)
GOOGLE_API_KEY=your_gemini_api_key_here

# Database Configuration (SQLite default, can be switched to PostgreSQL)
DATABASE_URL=sqlite:///./linkveil.db

# Security & Sessions
SECRET_KEY=generate_a_random_secret_key_here

# Analysis Heuristics
# Variants: 'balanced', 'fast', 'thorough'
MODEL_VARIANT=balanced

# Threat Intel feeds refresh interval (in seconds)
INTEL_REFRESH_INTERVAL=21600

# Logging
LOG_LEVEL=INFO
